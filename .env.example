# PostgreSQL
POSTGRES_HOST=db_sql
POSTGRES_PORT=5432
POSTGRES_DB=vitegourmand
POSTGRES_USER=vitegourmand
POSTGRES_PASSWORD=changeme_strong_password

# MongoDB
MONGO_HOST=db_mongo
MONGO_PORT=27017
MONGO_DB=vitegourmand_analytics
MONGO_USER=vitegourmand
MONGO_PASSWORD=changeme_mongo_password

# Backend
NODE_ENV=development
PORT=3000
JWT_SECRET=changeme_jwt_secret_min_32_chars_long
JWT_REFRESH_SECRET=changeme_jwt_refresh_secret_min_32
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=7d

# Email (Mailhog in dev)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=contact@vitegourmand.fr
SMTP_USER=
SMTP_PASS=

# Frontend
VITE_API_URL=http://localhost:3000/api
FRONTEND_URL=http://localhost:5173
# Origins CORS autorisées (séparés par virgule, sans espace)
# Ex prod: FRONTEND_URLS=https://vite-gourmand-three.vercel.app,https://www.vitegourmand.fr
FRONTEND_URLS=http://localhost:5173

# Admin seed account
ADMIN_EMAIL=admin@vitegourmand.fr
ADMIN_PASSWORD=changeme_admin_password

# Paiement acompte (Devis)
BANK_ACCOUNT_NAME=Vite & Gourmand
BANK_IBAN=FR76....
BANK_BIC=AGRIFRPP...
ON_SITE_ADDRESS=12 rue de la Paix, 33000 Bordeaux
ON_SITE_HOURS=Lun–Ven 9h–18h
ON_SITE_PHONE=05 00 00 00 00

# IA (Groq gratuit par défaut, ou OpenAI, Mistral, etc.)
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=