{
  "name": "vite-gourmand-api",
  "version": "1.0.0",
  "description": "API Backend pour Vite & Gourmand - ECF DWWM",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "seed:mongo": "node src/scripts/seedMongo.js",
    "seed:postgres": "node src/scripts/seedPostgres.js",
    "seed": "node src/scripts/seedPostgres.js && node src/scripts/seedMongo.js"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "setupFiles": [
      "<rootDir>/src/__tests__/setup.js"
    ]
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "nodemailer": "^6.9.15",
    "openai": "^4.73.0",
    "pg": "^8.13.0",
    "pino": "^9.14.0",
    "pino-pretty": "^13.1.3",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  }
}
